{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": ["schema_version", "student", "checks"],
    "properties": {
        "schema_version": {"type": "string"},
        "student": {
            "type": "object",
            "required": ["name", "group", "token_hash8"],
            "properties": {
                "name": {"type": "string"},
                "group": {"type": "string"},
                "token_hash8": {"type": "string", "minLength": 8, "maxLength": 8},
                "token": {"type": "string"}
            }
        },
        "yang": {
            "type": "object",
            "properties": {
                "ok": {"type": "boolean"},
                "evidence_sha": {"type": "string"}
            }
        },
        "webex": {
            "type": "object",
            "properties": {
                "ok": {"type": "boolean"},
                "room_title_contains_hash8": {"type": "boolean"},
                "evidence_sha": {"type": "string"}
            }
        },
        "pt": {
            "type": "object",
            "properties": {
                "ok": {"type": "boolean"},
                "empty_ticket_seen": {"type": "boolean"},
                "evidence_sha": {"type": "string"}
            }
        },
        "bonus": {
            "type": "object",
            "properties": {
                "optional_ok": {"type": "boolean"},
                "evidence_sha": {"type": "string"}
            }
        },
        "validation_passed": {"type": "boolean"},
        "checks": {
            "type": "object",
            "required": [
                "yang_interfaces_in_tree",
                "webex_room_title_has_token_hash8",
                "pt_empty_ticket_check",
                "pt_network_devices_ok",
                "pt_hosts_ok"
            ],
            "properties": {
                "yang_interfaces_in_tree": {"type": "boolean"},
                "webex_room_title_has_token_hash8": {"type": "boolean"},
                "pt_empty_ticket_check": {"type": "boolean"},
                "pt_network_devices_ok": {"type": "boolean"},
                "pt_hosts_ok": {"type": "boolean"},
                "docker_token_in_page": {"type": "boolean"}
            }
        }
    }
}